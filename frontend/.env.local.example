# Frontend env. Copy to .env.local for local dev.

# Backend SSE endpoint the dashboard streams from.
# Local dev: point at the backend on its localhost port, and run the backend
# with CORS_ORIGIN=http://localhost:3000 so the browser is allowed (SPEC §8.5).
# Production: https://api.niminal.xyz/stream
NEXT_PUBLIC_STREAM_URL=http://127.0.0.1:8080/stream
