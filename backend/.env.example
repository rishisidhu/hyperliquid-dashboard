# Backend configuration (Phase 1). Copy to .env or export in the environment.
# All values are optional; defaults shown are safe for local development.

# Interface to bind the HTTP server to. MUST stay 127.0.0.1 in production —
# nginx is the only public door (SPEC §6, §8.5). Do not bind 0.0.0.0.
HOST=127.0.0.1

# Port the Node process listens on (localhost-only). nginx proxy_passes here.
PORT=8080

# Upstream poll cadence in ms. ~2s per SPEC §5.2. A single poller serves all
# clients (fan-out). Floored internally so it can't be set abusively low.
POLL_INTERVAL_MS=2000

# Hard cap on concurrent SSE clients. Beyond this the server replies 503
# (SPEC §8.5 DoS mitigation). Tune for the shared box later.
MAX_SSE_CLIENTS=200

# SSE heartbeat interval in ms — keeps proxies open and drops dead sockets.
SSE_HEARTBEAT_MS=15000

# --- Phase 2: OI-snapshot persistence (SPEC §5.1) ---------------------------

# Path to the SQLite file. Defaults to project-local ./data/oi.sqlite. In
# production set this inside the service user's OWN directory (§8.5 isolation)
# — never near the blog's data dirs.
OI_DB_PATH=./data/oi.sqlite

# How often to append one OI sample per coin (30–60s per SPEC §5.1).
OI_SNAPSHOT_INTERVAL_MS=60000

# Prune snapshots older than this (~1h per SPEC §5.1) to keep the file small.
OI_RETENTION_MS=3600000

# OI-trend window: compare OI now vs ~this long ago (15–30 min per SPEC §4.2).
OI_TREND_WINDOW_MS=1200000

# Below this absolute % change, the trend reads "flat" (noise deadband).
OI_TREND_DEADBAND_PCT=1.0

# Board SIGNIFICANCE floor ($): "is this a real market?" — shared with the
# frontend hide-balanced filter (emitted in the board payload). $1M drops the
# illiquid micro-market tail.
OI_FLOOR_USD=1000000

# HEADLINE floor ($): higher than the significance floor so the marquee cards
# showcase liquid, credible crowding (ADA/TRUMP-class) rather than $2–4M froth.
HEADLINE_OI_FLOOR_USD=10000000

# --- Phase 5: cross-venue funding + funding-history sparklines --------------

# Cross-venue (predictedFundings) poll cadence. Funding is hourly — slow is fine.
PREDICTED_FUNDINGS_INTERVAL_MS=60000

# Per-coin funding-history cache TTL (fan-out: ~1 upstream fetch per coin/window).
FUNDING_HISTORY_TTL_MS=300000

# How far back the sparkline reaches (hourly samples from Hyperliquid).
FUNDING_HISTORY_LOOKBACK_HOURS=168

# perpsAtOpenInterestCap poll cadence (the capped set changes slowly).
OI_CAP_INTERVAL_MS=45000
